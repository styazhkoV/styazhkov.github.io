---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body style="font-family: sans-serif; background: #f4f4f9; color: #333; margin: 0; padding: 2rem;">
		<nav>
			<a href="/">Главная</a> | <a href="/about">Обо мне</a>
		</nav>
		<hr />
		<slot /> <footer style="margin-top: 2rem; font-size: 0.8rem;">
			© {new Date().getFullYear()} Snow Solutions
		</footer>
	</body>
</html>